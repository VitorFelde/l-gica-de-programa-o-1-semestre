/*Faça um programa que:

leia um número inteiro N
imprima de 1 até N usando while*/


#include <stdio.h>

int main()
{
  
  int i = 1, n;
  
  printf ("Digite um número maior que 1: ");
  scanf ("%d", &n);
  
  while (i <= n) {
     
      printf ("%d\n", i);
     
      i++;
      
  }

    return 0;
}
